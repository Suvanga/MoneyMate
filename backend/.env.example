# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/moneymatedb?retryWrites=true&w=majority

# Server Port
PORT=4001

# Google Cloud Vision API Credentials
GOOGLE_APPLICATION_CREDENTIALS=./api_key/your-service-account-key.json

# OpenAI API Key
OPENAI_API_KEY=sk-proj-your-actual-api-key-here

# Auth0 Configuration (Optional - uncomment if using Auth0)
# AUTH0_DOMAIN=your-auth0-domain.us.auth0.com
# AUTH0_CLIENT_ID=your-auth0-client-id
# AUTH0_CLIENT_SECRET=your-auth0-client-secret
